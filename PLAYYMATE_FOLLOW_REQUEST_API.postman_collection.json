						"description": "Trying to accept a non-existent request."
					},
					"response": [
						{
							"name": "Not Found",
							"status": "Not Found",
							"code": 404,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"error\",\n  \"message\": \"Follow request not found\",\n  \"data\": null,\n  \"error_code\": \"NOT_FOUND\"\n}"
						}
					]
				},
				{
					"name": "409 - Already Following",
					"request": {
						"method": "POST",
