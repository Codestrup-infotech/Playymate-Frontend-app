{
  "info": {
    "name": "Playymate - Account Management API",
    "description": "Postman collection for testing Account Management features: Deactivation, Deletion, Sessions, Phone/Email Change",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Phase 1: Account Deactivation & Deletion",
      "item": [
        {
          "name": "1.1 Get Account Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/me/account-status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "account-status"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Account status field exists', () => {",
                  "        pm.expect(jsonData.data).to.have.property('account_status');",
                  "    });",
                  "    console.log('Account Status:', JSON.stringify(jsonData.data, null, 2));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Deactivate Account",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users/me/deactivate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "deactivate"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"reason\": \"Taking a break from the platform\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Deactivation successful message', () => {",
                  "        pm.expect(jsonData.message).to.include('deactivated');",
                  "    });",
                  "    console.log('Deactivation Response:', JSON.stringify(jsonData, null, 2));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Reactivate Account",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users/me/reactivate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "reactivate"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Reactivation successful message', () => {",
                  "        pm.expect(jsonData.message).to.include('reactivated');",
                  "    });",
                  "    console.log('Reactivation Response:', JSON.stringify(jsonData, null, 2));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.4 Request Account Deletion",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users/me/delete-request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "delete-request"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"reason\": \"No longer need the platform\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Deletion scheduled message', () => {",
                  "        pm.expect(jsonData.message).to.include('deletion');",
                  "    });",
                  "    pm.test('Grace period days returned', () => {",
                  "        pm.expect(jsonData.data).to.have.property('grace_period_days');",
                  "    });",
                  "    console.log('Deletion Request Response:', JSON.stringify(jsonData, null, 2));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.5 Cancel Deletion Request",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/users/me/delete-request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "delete-request"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Cancellation successful message', () => {",
                  "        pm.expect(jsonData.message).to.include('cancelled');",
                  "    });",
                  "    console.log('Cancel Deletion Response:', JSON.stringify(jsonData, null, 2));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Phase 2: Active Sessions / Device Management",
      "item": [
        {
          "name": "2.1 Get Active Sessions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/sessions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "sessions"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Sessions array exists', () => {",
                  "        pm.expect(jsonData.data).to.have.property('sessions');",
                  "    });",
                  "    pm.test('Total sessions count exists', () => {",
                  "        pm.expect(jsonData.data).to.have.property('total');",
                  "    });",
                  "    ",
                  "    // Store first session ID for revoke test",
                  "    if (jsonData.data.sessions.length > 0) {",
                  "        const firstSession = jsonData.data.sessions.find(s => !s.is_current);",
                  "        if (firstSession) {",
                  "            pm.collectionVariables.set('sessionId', firstSession.session_id);",
                  "        }",
                  "    }",
                  "    console.log('Active Sessions:', JSON.stringify(jsonData.data, null, 2));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Revoke Specific Session",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/auth/sessions/{{sessionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "sessions",
                "{{sessionId}}"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Session revoked message', () => {",
                  "        pm.expect(jsonData.message).to.include('revoked');",
                  "    });",
                  "    console.log('Revoke Session Response:', JSON.stringify(jsonData, null, 2));",
                  "}",
                  "",
                  "if (pm.response.code === 400) {",
                  "    const jsonData = pm.response.json();",
                  "    console.log('Error (Cannot revoke current session):', jsonData.message);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Phase 3: Change Phone Number",
      "item": [
        {
          "name": "3.1 Send OTP to New Phone",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users/me/change-phone/send-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "change-phone",
                "send-otp"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"new_phone\": \"+919876543210\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('OTP sent message', () => {",
                  "        pm.expect(jsonData.message).to.include('OTP sent');",
                  "    });",
                  "    pm.test('Masked phone returned', () => {",
                  "        pm.expect(jsonData.data).to.have.property('masked_phone');",
                  "    });",
                  "    console.log('Send Phone OTP Response:', JSON.stringify(jsonData, null, 2));",
                  "}",
                  "",
                  "if (pm.response.code === 409) {",
                  "    const jsonData = pm.response.json();",
                  "    console.log('Error (Phone already in use):', jsonData.message);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Verify and Commit New Phone",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users/me/change-phone/verify-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "change-phone",
                "verify-otp"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"new_phone\": \"+919876543210\",\n    \"otp\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Phone updated message', () => {",
                  "        pm.expect(jsonData.message).to.include('updated');",
                  "    });",
                  "    console.log('Verify Phone Change Response:', JSON.stringify(jsonData, null, 2));",
                  "}",
                  "",
                  "if (pm.response.code === 400) {",
                  "    const jsonData = pm.response.json();",
                  "    console.log('Error (Invalid OTP):', jsonData.message);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Phase 3: Change Email Address",
      "item": [
        {
          "name": "3.3 Send OTP to New Email",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users/me/change-email/send-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "change-email",
                "send-otp"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"new_email\": \"newemail@example.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Verification email sent message', () => {",
                  "        pm.expect(jsonData.message).to.include('Verification code sent');",
                  "    });",
                  "    pm.test('Masked email returned', () => {",
                  "        pm.expect(jsonData.data).to.have.property('masked_email');",
                  "    });",
                  "    console.log('Send Email OTP Response:', JSON.stringify(jsonData, null, 2));",
                  "}",
                  "",
                  "if (pm.response.code === 409) {",
                  "    const jsonData = pm.response.json();",
                  "    console.log('Error (Email already in use):', jsonData.message);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3.4 Verify and Commit New Email",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users/me/change-email/verify-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me",
                "change-email",
                "verify-otp"
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"new_email\": \"newemail@example.com\",\n    \"otp\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.test('Response status is success', () => {",
                  "        pm.expect(jsonData.status).to.eql('success');",
                  "    });",
                  "    pm.test('Email updated message', () => {",
                  "        pm.expect(jsonData.message).to.include('updated');",
                  "    });",
                  "    console.log('Verify Email Change Response:', JSON.stringify(jsonData, null, 2));",
                  "}",
                  "",
                  "if (pm.response.code === 400) {",
                  "    const jsonData = pm.response.json();",
                  "    console.log('Error (Invalid OTP):', jsonData.message);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth - Login (For Testing)",
      "item": [
        {
          "name": "Login with OTP",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"phone\": \"+919999999999\",\n    \"otp\": \"123456\",\n    \"device_info\": {\n        \"platform\": \"ios\",\n        \"user_agent\": \"Playymate/1.0.0\",\n        \"ip\": \"127.0.0.1\"\n    }\n}"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "    const jsonData = pm.response.json();",
                    "    pm.test('Response status is success', () => {",
                    "        pm.expect(jsonData.status).to.eql('success');",
                    "    });",
                    "    pm.test('Access token returned', () => {",
                    "        pm.expect(jsonData.data).to.have.property('access_token');",
                    "    });",
                    "    pm.collectionVariables.set('accessToken', jsonData.data.access_token);",
                    "    console.log('Login successful, token stored');",
                    "}"
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  ]
}