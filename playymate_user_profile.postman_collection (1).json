                            "raw": "{\n  \"file_name\": \"cover.jpg\",\n  \"mime_type\": \"image/jpeg\",\n  \"size_bytes\": 409600\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/users/{{user_id}}/cover-photo/presign",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "users",
                                "{{user_id}}",
                                "cover-photo",
                                "presign"
                            ]
                        },
                        "description": "Step 1 of cover photo upload flow. Returns a presigned PUT URL valid for 5 min.\nClient uploads the image directly to Wasabi using upload_url, then passes file_url when confirming."
                    }
