									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"is_private\": true\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/users/me/privacy/account",
									"host": ["{{baseUrl}}"],
									"path": ["users", "me", "privacy", "account"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"message\": \"Account privacy updated\",\n  \"data\": {\n    \"is_private\": true,\n    \"pending_follow_requests_count\": 5\n  },\n  \"error_code\": null\n}"
						}
					]
				}
			]
		},
