                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"file_url\": \"{{cover_file_url}}\",\n  \"file_key\": \"{{cover_file_key}}\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/users/{{user_id}}/cover-photo/confirm",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "users",
                                "{{user_id}}",
                                "cover-photo",
                                "confirm"
                            ]
                        },
                        "description": "Step 2 of cover photo upload flow. Confirm cover photo upload after file is uploaded to the presigned URL."
                    }
                },
                {
                    "name": "3. Delete Cover Photo",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/users/{{user_id}}/cover-photo",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "users",
                                "{{user_id}}",
                                "cover-photo"
                            ]
                        },
                        "description": "Delete user's cover photo"
                    }
                }
            ]
        },
        {
