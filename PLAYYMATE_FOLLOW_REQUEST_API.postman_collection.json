{
	"info": {
		"_postman_id": "follow-request-api",
		"name": "Playymate Follow Request API",
		"description": "Follow Request System - Private Account Follow Requests, Accept/Reject, Pending Requests Management",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000/api/v1"
		},
		{
			"key": "authToken",
			"value": "YOUR_JWT_TOKEN"
		},
		{
			"key": "userId",
			"value": "YOUR_USER_ID"
		},
		{
			"key": "targetUserId",
			"value": "TARGET_USER_ID"
		},
		{
			"key": "requestId",
			"value": "FOLLOW_REQUEST_ID"
		}
	],
	"item": [
		{
			"name": "Follow Requests",
			"item": [
				{
					"name": "Send Follow Request (Private Account)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"message\": \"Hey! I'd like to follow you.\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/users/{{targetUserId}}/follow",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{targetUserId}}", "follow"]
						},
						"description": "Send a follow request to a private account. Returns 202 with request_id."
					},
					"response": [
						{
							"name": "Follow Request Sent",
							"originalRequest": {
								"method": "POST",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"},
									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"message\": \"Hey! I'd like to follow you.\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/users/{{targetUserId}}/follow",
									"host": ["{{baseUrl}}"],
									"path": ["users", "{{targetUserId}}", "follow"]
								}
							},
							"status": "Accepted",
							"code": 202,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"message\": \"Follow request sent\",\n  \"data\": {\n    \"request_id\": \"507f1f77bcf86cd799439011\",\n    \"status\": \"pending\",\n    \"created_at\": \"2026-03-27T10:30:00.000Z\"\n  },\n  \"error_code\": null\n}"
						},
						{
							"name": "Already Following",
							"originalRequest": {
								"method": "POST",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"},
									{"key": "Content-Type", "value": "application/json"}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"message\": \"Hey!\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/users/{{targetUserId}}/follow",
									"host": ["{{baseUrl}}"],
									"path": ["users", "{{targetUserId}}", "follow"]
								}
							},
							"status": "Conflict",
							"code": 409,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"error\",\n  \"message\": \"Already following this user\",\n  \"data\": null,\n  \"error_code\": \"ALREADY_FOLLOWING\"\n}"
						}
					]
				},
				{
					"name": "Accept Follow Request",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/follow-requests/{{requestId}}/accept",
							"host": ["{{baseUrl}}"],
							"path": ["follow-requests", "{{requestId}}", "accept"]
						},
						"description": "Accept a pending follow request. Only the target user can accept."
					},
					"response": [
						{
							"name": "Request Accepted",
							"originalRequest": {
								"method": "POST",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"}
								],
								"url": {
									"raw": "{{baseUrl}}/follow-requests/{{requestId}}/accept",
									"host": ["{{baseUrl}}"],
									"path": ["follow-requests", "{{requestId}}", "accept"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"message\": \"Follow request accepted\",\n  \"data\": {\n    \"request_id\": \"507f1f77bcf86cd799439011\",\n    \"status\": \"accepted\",\n    \"responded_at\": \"2026-03-27T10:35:00.000Z\"\n  },\n  \"error_code\": null\n}"
						}
					]
				},
				{
					"name": "Reject Follow Request",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/follow-requests/{{requestId}}/reject",
							"host": ["{{baseUrl}}"],
							"path": ["follow-requests", "{{requestId}}", "reject"]
						},
						"description": "Reject a pending follow request. Only the target user can reject."
					},
					"response": [
						{
							"name": "Request Rejected",
							"originalRequest": {
								"method": "POST",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"}
								],
								"url": {
									"raw": "{{baseUrl}}/follow-requests/{{requestId}}/reject",
									"host": ["{{baseUrl}}"],
									"path": ["follow-requests", "{{requestId}}", "reject"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"message\": \"Follow request rejected\",\n  \"data\": {\n    \"request_id\": \"507f1f77bcf86cd799439011\",\n    \"status\": \"rejected\",\n    \"responded_at\": \"2026-03-27T10:35:00.000Z\"\n  },\n  \"error_code\": null\n}"
						}
					]
				},
				{
					"name": "Cancel Follow Request",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/follow-requests/{{requestId}}",
							"host": ["{{baseUrl}}"],
							"path": ["follow-requests", "{{requestId}}"]
						},
						"description": "Cancel a pending follow request. Only the requester can cancel."
					},
					"response": [
						{
							"name": "Request Cancelled",
							"originalRequest": {
								"method": "DELETE",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"}
								],
								"url": {
									"raw": "{{baseUrl}}/follow-requests/{{requestId}}",
									"host": ["{{baseUrl}}"],
									"path": ["follow-requests", "{{requestId}}"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"message\": \"Follow request cancelled\",\n  \"data\": {\n    \"request_id\": \"507f1f77bcf86cd799439011\",\n    \"status\": \"cancelled\"\n  },\n  \"error_code\": null\n}"
						}
					]
				},
				{
					"name": "Get Pending Requests (Received)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/follow-requests/pending?limit=20&cursor=",
							"host": ["{{baseUrl}}"],
							"path": ["follow-requests", "pending"],
							"query": [
								{"key": "limit", "value": "20"},
								{"key": "cursor", "value": "", "disabled": true}
							]
						},
						"description": "Get all pending follow requests received by the authenticated user."
					},
					"response": [
						{
							"name": "Pending Requests List",
							"originalRequest": {
								"method": "GET",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"}
								],
								"url": {
									"raw": "{{baseUrl}}/follow-requests/pending?limit=20",
									"host": ["{{baseUrl}}"],
									"path": ["follow-requests", "pending"],
									"query": [
										{"key": "limit", "value": "20"}
									]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"requests\": [\n      {\n        \"request_id\": \"507f1f77bcf86cd799439011\",\n        \"requester\": {\n          \"_id\": \"507f1f77bcf86cd799439012\",\n          \"username\": \"johndoe\",\n          \"full_name\": \"John Doe\",\n          \"profile_image_url\": \"https://cdn.playymate.com/profiles/johndoe.jpg\"\n        },\n        \"message\": \"Hey! I'd like to follow you.\",\n        \"status\": \"pending\",\n        \"created_at\": \"2026-03-27T10:30:00.000Z\"\n      }\n    ],\n    \"pagination\": {\n      \"limit\": 20,\n      \"has_more\": false,\n      \"next_cursor\": null\n    }\n  },\n  \"error_code\": null\n}"
						}
					]
				},
				{
					"name": "Get Sent Requests",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/follow-requests/sent?limit=20&cursor=",
							"host": ["{{baseUrl}}"],
							"path": ["follow-requests", "sent"],
							"query": [
								{"key": "limit", "value": "20"},
								{"key": "cursor", "value": "", "disabled": true}
							]
						},
						"description": "Get all follow requests sent by the authenticated user."
					},
					"response": [
						{
							"name": "Sent Requests List",
							"originalRequest": {
								"method": "GET",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"}
								],
								"url": {
									"raw": "{{baseUrl}}/follow-requests/sent?limit=20",
									"host": ["{{baseUrl}}"],
									"path": ["follow-requests", "sent"],
									"query": [
										{"key": "limit", "value": "20"}
									]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"requests\": [\n      {\n        \"request_id\": \"507f1f77bcf86cd799439011\",\n        \"target\": {\n          \"_id\": \"507f1f77bcf86cd799439013\",\n          \"username\": \"janedoe\",\n          \"full_name\": \"Jane Doe\",\n          \"profile_image_url\": \"https://cdn.playymate.com/profiles/janedoe.jpg\"\n        },\n        \"message\": \"Hey! I'd like to follow you.\",\n        \"status\": \"pending\",\n        \"created_at\": \"2026-03-27T10:30:00.000Z\"\n      }\n    ],\n    \"pagination\": {\n      \"limit\": 20,\n      \"has_more\": false,\n      \"next_cursor\": null\n    }\n  },\n  \"error_code\": null\n}"
						}
					]
				},
				{
					"name": "Check Follow Request Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users/{{targetUserId}}/follow-request-status",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{targetUserId}}", "follow-request-status"]
						},
						"description": "Check the follow request status with a specific user."
					},
					"response": [
						{
							"name": "Status - Pending",
							"originalRequest": {
								"method": "GET",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"}
								],
								"url": {
									"raw": "{{baseUrl}}/users/{{targetUserId}}/follow-request-status",
									"host": ["{{baseUrl}}"],
									"path": ["users", "{{targetUserId}}", "follow-request-status"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"request_id\": \"507f1f77bcf86cd799439011\",\n    \"status\": \"pending\",\n    \"is_requester\": true,\n    \"created_at\": \"2026-03-27T10:30:00.000Z\"\n  },\n  \"error_code\": null\n}"
						},
						{
							"name": "Status - None",
							"originalRequest": {
								"method": "GET",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"}
								],
								"url": {
									"raw": "{{baseUrl}}/users/{{targetUserId}}/follow-request-status",
									"host": ["{{baseUrl}}"],
									"path": ["users", "{{targetUserId}}", "follow-request-status"]
								}
							},
							"status": "OK",
							"code": 200,
							"header": [
								{"key": "Content-Type", "value": "application/json"}
							],
							"body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"request_id\": null,\n    \"status\": \"none\",\n    \"is_requester\": false,\n    \"created_at\": null\n  },\n  \"error_code\": null\n}"
						}
					]
				}
			]
		},
		{
			"name": "Privacy Settings",
			"item": [
