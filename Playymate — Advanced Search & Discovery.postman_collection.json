    {
      "name": "🔄 End-to-End Search Flow",
      "item": [
        {
          "name": "Step 1 → Global Search",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Global search successful', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const d = pm.response.json().data;",
                  "  pm.expect(d).to.have.property('posts');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
