          "name": "1. Global Search",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const d = pm.response.json().data;",
                  "  if (d && d.posts && d.posts.length > 0) {",
                  "    pm.collectionVariables.set('result_id', d.posts[0]._id);",
                  "  }",
                  "  console.log('Global search executed successfully');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"q\": \"yoga classes near me\",\n  \"latitude\": 18.5204,\n  \"longitude\": 73.8567,\n  \"distance\": 10,\n  \"limit\": 20,\n  \"page\": 1,\n  \"sort\": \"relevance\"\n}"
