                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"Response has profile_completion_card\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.data.profile_completion_card).to.be.an('object');",
                                    "});",
                                    "",
                                    "pm.test(\"Profile completion card has enabled flag\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.data.profile_completion_card.enabled).to.be.a('boolean');",
                                    "});",
                                    "",
                                    "pm.test(\"Profile completion card has tasks\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.data.profile_completion_card.tasks).to.have.property('username');",
                                    "    pm.expect(jsonData.data.profile_completion_card.tasks).to.have.property('profile_main_type');",
                                    "    pm.expect(jsonData.data.profile_completion_card.tasks).to.have.property('bio');",
                                    "});",
                                    "",
                                    "pm.test(\"Profile completion card has tiles\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    const tiles = jsonData.data.profile_completion_card.tiles;",
                                    "    pm.expect(tiles).to.be.an('array');",
                                    "    pm.expect(tiles.length).to.be.greaterThan(0);",
                                    "});"
                                ]
                            }
                        }
                    ]
