							"name": "Privacy Settings",
							"originalRequest": {
								"method": "GET",
								"header": [
									{"key": "Authorization", "value": "Bearer {{authToken}}"}
								],
								"url": {
									"raw": "{{baseUrl}}/users/me/privacy/account",
									"host": ["{{baseUrl}}"],
									"path": ["users", "me", "privacy", "account"]
								}
