    {
      "name": "08 - End-to-End Flow Test",
      "item": [
        {
          "name": "Complete Notification Flow - Register Token -> Create Content -> Like -> Check Notification",
          "item": [
            {
              "name": "1. Register FCM Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('FCM Token registered', function() {",
                      "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/notifications/fcm-token",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{authToken}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"token\": \"e2e_test_token_123\",\n    \"device_type\": \"android\"\n}"
                }
              }
            },
            {
              "name": "2. Get Initial Unread Count",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const jsonData = pm.response.json();",
                      "    pm.environment.set('initialCount', jsonData.data.unread_count);",
                      "    console.log('Initial count:', jsonData.data.unread_count);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/notifications/count",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{authToken}}"
                  }
                ]
              }
            },
            {
              "name": "3. Trigger Like (Creates Notification)",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Like successful', function() {",
                      "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "url": "{{baseUrl}}/likes",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{authToken}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"content_id\": \"{{postId}}\",\n    \"content_type\": \"post\",\n    \"reaction\": \"like\"\n}"
                }
              }
            },
            {
              "name": "4. Wait 1 Second for Processing",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "setTimeout(function() {}, 1000);",
                      "console.log('Waited for notification processing');"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/health",
                "header": []
              }
            },
            {
              "name": "5. Get New Unread Count",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const jsonData = pm.response.json();",
                      "    const initialCount = parseInt(pm.environment.get('initialCount') || '0');",
                      "    const newCount = jsonData.data.unread_count;",
                      "    console.log('Initial:', initialCount, 'New:', newCount);",
                      "    pm.test('Unread count increased', function() {",
                      "        pm.expect(newCount).to.be.greaterThan(initialCount);",
                      "    });",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "GET",
                "url": "{{baseUrl}}/notifications/count",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{authToken}}"
                  }
                ]
              }
            },
            {
              "name": "6. Get Latest Notification",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    const jsonData = pm.response.json();",
                      "    const latestNotif = jsonData.data.notifications[0];",
                      "    console.log('Latest notification type:', latestNotif.notification_type);",
                      "    pm.test('Latest notification is post_liked', function() {",
                      "        pm.expect(latestNotif.notification_type).to.eql('post_liked');",
                      "    });",
                      "    pm.test('Notification is unread', function() {",
                      "        pm.expect(latestNotif.is_read).to.be.false;",
                      "    });",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
