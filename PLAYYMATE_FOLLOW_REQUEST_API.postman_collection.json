		{
			"name": "Error Responses",
			"item": [
				{
					"name": "401 - Unauthorized",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/follow-requests/pending",
							"host": ["{{baseUrl}}"],
							"path": ["follow-requests", "pending"]
						},
						"description": "Request without authentication token."
