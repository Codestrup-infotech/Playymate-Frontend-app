						}
					]
				},
				{
					"name": "404 - Request Not Found",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/follow-requests/invalid_id/accept",
							"host": ["{{baseUrl}}"],
							"path": ["follow-requests", "invalid_id", "accept"]
