					"name": "403 - Forbidden",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/follow-requests/{{requestId}}/accept",
							"host": ["{{baseUrl}}"],
							"path": ["follow-requests", "{{requestId}}", "accept"]
