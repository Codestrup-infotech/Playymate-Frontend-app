  "item": [
    {
      "name": "Sharing Endpoints",
      "item": [
        {
          "name": "7.1 - Share a Post (external)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/shares",
              "host": ["{{base_url}}"],
              "path": ["shares"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userA_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content_id\": \"{{postId}}\",\n    \"content_type\": \"post\",\n    \"shared_to\": \"external\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.data) {",
                  "        pm.environment.set('shareId', jsonData.data._id);",
                  "        console.log('Share created: ' + jsonData.data.share_id);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Response status is 201', function() {",
                  "    pm.expect(pm.response.status).to.eq(201);",
                  "});",
                  "",
                  "pm.test('Response has success: true', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "7.2 - Share a Post to DM",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/shares",
              "host": ["{{base_url}}"],
              "path": ["shares"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userA_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"content_id\": \"{{postId}}\",\n    \"content_type\": \"post\",\n    \"shared_to\": \"direct_message\",\n    \"recipient_id\": \"{{otherUserId}}\",\n    \"message\": \"Check this out!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.data && jsonData.data.conversation_id) {",
                  "        pm.environment.set('conversationId', jsonData.data.conversation_id);",
                  "        console.log('Share to DM created, conversation: ' + jsonData.data.conversation_id);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Response status is 201', function() {",
                  "    pm.expect(pm.response.status).to.eq(201);",
                  "});",
                  "",
                  "pm.test('Response has conversation_id', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.conversation_id).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
